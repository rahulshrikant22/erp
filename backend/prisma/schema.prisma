model CustomerAccount {
  id                  String    @id @default(uuid())
  accountCode         String    @unique @map("account_code")
  companyName         String    @map("company_name")
  primaryContactName  String?   @map("primary_contact_name")
  primaryEmail        String    @map("primary_email")
  primaryPhone        String?   @map("primary_phone")
  accountType         String    @map("account_type") // architect | dealer | direct | corporate
  gstin               String?
  pan                 String?
  isActive            Boolean   @default(true) @map("is_active")
  isVerified          Boolean   @default(false) @map("is_verified")
  verifiedAt          DateTime? @map("verified_at")
  signupRequestId     String?   @unique @map("signup_request_id")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdById         String?   @map("created_by_id")
  updatedById         String?   @map("updated_by_id")
  isDeleted           Boolean   @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at")
  deletedById         String?   @map("deleted_by_id")

  signupRequest       CustomerSignupRequest? @relation(fields: [signupRequestId], references: [id], onDelete: SetNull)
  users               CustomerUser[]
  portalPermissions   CustomerPortalPermission[]

  @@index([accountType])
  @@index([isActive])
  @@index([isVerified])
  @@index([isDeleted])
  @@map("customer_accounts")
  @@schema("core")
}

model CustomerUser {
  id                  String    @id @default(uuid())
  customerAccountId   String    @map("customer_account_id")
  email               String
  passwordHash        String    @map("password_hash") // @encrypted
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  phone               String?
  role                String    @default("regular") // admin | regular
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdById         String?   @map("created_by_id")
  updatedById         String?   @map("updated_by_id")

  account               CustomerAccount    @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  oauthConnections      OauthConnection[]
  dpdpConsents          DpdpConsent[]
  sessions              UserSession[]
  passwordResetTokens   PasswordResetToken[]

  @@unique([customerAccountId, email])
  @@index([customerAccountId])
  @@index([email])
  @@index([isActive])
  @@map("customer_users")
  @@schema("core")
}

model CustomerSignupRequest {
  id                String    @id @default(uuid())
  companyName       String    @map("company_name")
  contactName       String    @map("contact_name")
  email             String
  phone             String?
  accountType       String    @map("account_type")
  businessProofUrl  String?   @map("business_proof_url")
  status            String    @default("pending") // pending | approved | rejected
  submittedAt       DateTime  @default(now()) @map("submitted_at")
  reviewedById      String?   @map("reviewed_by_id")
  reviewedAt        DateTime? @map("reviewed_at")
  reviewNotes       String?   @map("review_notes")

  approvedAccount   CustomerAccount?

  @@index([status])
  @@index([email])
  @@map("customer_signup_requests")
  @@schema("core")
}

model CustomerPortalPermission {
  id                  String   @id @default(uuid())
  customerAccountId   String   @map("customer_account_id")
  permissionCode      String   @map("permission_code")
  grantedAt           DateTime @default(now()) @map("granted_at")
  grantedById         String?  @map("granted_by_id")

  account             CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@unique([customerAccountId, permissionCode])
  @@index([customerAccountId])
  @@map("customer_portal_permissions")
  @@schema("core")
}

// =============================================================================
// SECTION 8 — Payment Foundation (3 tables)
// =============================================================================

model PaymentGateway {
  id              String   @id @default(uuid())
  gatewayCode     String   @unique @map("gateway_code") // razorpay | stripe | ...
  displayName     String   @map("display_name")
  configuration   Json     // @encrypted
  isTestMode      Boolean  @default(true) @map("is_test_mode")
  isPrimary       Boolean  @default(false) @map("is_primary")
  isActive        Boolean  @default(true) @map("is_active")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String?  @map("created_by_id")
  updatedById     String?  @map("updated_by_id")

  transactions    PaymentTransaction[]

  @@index([isActive])
  @@index([isPrimary])
  @@map("payment_gateways")
  @@schema("core")
}

model PaymentTransaction {
  id                    String    @id @default(uuid())
  transactionCode       String    @unique @map("transaction_code")
  gatewayId             String?   @map("gateway_id")
  paymentMode           String    @map("payment_mode") // online | bank_transfer | cheque | cash
  relatedEntityType     String?   @map("related_entity_type")
  relatedEntityId       String?   @map("related_entity_id")
  amount                Decimal   @db.Decimal(18, 2)
  currency              String    @default("INR")
  status                String    @default("initiated") // initiated | pending | success | failed | refunded
  gatewayTransactionId  String?   @map("gateway_transaction_id")
  gatewayPaymentId      String?   @map("gateway_payment_id")
  utrNumber             String?   @map("utr_number")
  chequeNumber          String?   @map("cheque_number")
  chequeDate            DateTime? @map("cheque_date") @db.Date
  payerName             String?   @map("payer_name")
  notes                 String?

  initiatedAt           DateTime  @default(now()) @map("initiated_at")
  completedAt           DateTime? @map("completed_at")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdById           String?   @map("created_by_id")
  updatedById           String?   @map("updated_by_id")

  gateway               PaymentGateway? @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  refunds               PaymentRefund[]

  @@index([gatewayId])
  @@index([paymentMode])
  @@index([status])
  @@index([relatedEntityType, relatedEntityId])
  @@map("payment_transactions")
  @@schema("core")
}

model PaymentRefund {
  id                  String    @id @default(uuid())
  refundCode          String    @unique @map("refund_code")
  transactionId       String    @map("transaction_id")
  amount              Decimal   @db.Decimal(18, 2)
  currency            String    @default("INR")
  reason              String?
  status              String    @default("initiated") // initiated | pending | success | failed
  gatewayRefundId     String?   @map("gateway_refund_id")
  initiatedAt         DateTime  @default(now()) @map("initiated_at")
  completedAt         DateTime? @map("completed_at")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdById         String?   @map("created_by_id")
  updatedById         String?   @map("updated_by_id")

  transaction         PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([status])
  @@map("payment_refunds")
  @@schema("core")
}

// =============================================================================
// SECTION 9 — Documents / Numbering / Settings (3 tables)
// =============================================================================

model Document {
  id                  String    @id @default(uuid())
  documentType        String    @map("document_type")
  name                String
  filePath            String    @map("file_path")
  fileSize            BigInt?   @map("file_size")
  mimeType            String?   @map("mime_type")
  relatedEntityType   String?   @map("related_entity_type")
  relatedEntityId     String?   @map("related_entity_id")
  uploadedById        String?   @map("uploaded_by_id")
  uploadedAt          DateTime  @default(now()) @map("uploaded_at")
  version             Int       @default(1)
  parentDocumentId    String?   @map("parent_document_id")
  // Soft delete (P0-12). The physical file is intentionally NOT removed —
  // we keep it for audit / regulatory recovery. The flag just hides the row
  // from normal lists and downloads.
  isDeleted           Boolean   @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at")
  deletedById         String?   @map("deleted_by_id")

  parent              Document?  @relation("DocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  versions            Document[] @relation("DocumentVersions")

  @@index([documentType])
  @@index([relatedEntityType, relatedEntityId])
  @@index([parentDocumentId])
  @@index([isDeleted])
  @@map("documents")
  @@schema("core")
}

model NumberingSeries {
  id              String    @id @default(uuid())
  seriesCode      String    @unique @map("series_code") // ORD | INV | PO | GRN | ...
  name            String
  prefix          String?
  yearFormat      String    @default("YYYY") @map("year_format") // YYYY | YY | none
  separator       String    @default("/")
  paddingLength   Int       @default(4) @map("padding_length")
  currentNumber   Int       @default(0) @map("current_number")
  resetYearly     Boolean   @default(true) @map("reset_yearly")
  lastResetAt     DateTime? @map("last_reset_at")
  isActive        Boolean   @default(true) @map("is_active")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdById     String?   @map("created_by_id")
  updatedById     String?   @map("updated_by_id")

  @@index([isActive])
  @@map("numbering_series")
  @@schema("core")
}

model SystemSetting {
  id              String    @id @default(uuid())
  settingKey      String    @unique @map("setting_key")
  settingValue    String?   @map("setting_value") @db.Text
  dataType        String    @map("data_type") // string | integer | boolean | json
  category        String?
  description     String?
  isUserEditable  Boolean   @default(true) @map("is_user_editable")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdById     String?   @map("created_by_id")
  updatedById     String?   @map("updated_by_id")

  @@index([category])
  @@map("system_settings")
  @@schema("core")
}
