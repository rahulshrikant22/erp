}

// =============================================================================
// SECTION 6 — Communication (6 tables)
// =============================================================================

model EmailProvider {
  id              String   @id @default(uuid())
  providerName    String   @map("provider_name") // smtp | sendgrid | ses | mailgun
  // providerCode is the IMPLEMENTATION TYPE (smtp / sendgrid / ses / mailgun
  // / log), NOT a unique identifier. Multiple rows with the same code are
  // expected (e.g. a primary SMTP + a fallback SMTP from a different host).
  providerCode    String   @map("provider_code")
  configuration   Json     // @encrypted (smtp creds, API keys)
  fromEmail       String   @map("from_email")
  fromName        String?  @map("from_name")
  isPrimary       Boolean  @default(false) @map("is_primary")
  isActive        Boolean  @default(true) @map("is_active")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String?  @map("created_by_id")
  updatedById     String?  @map("updated_by_id")

  notificationLogs NotificationLog[]

  @@index([isActive])
  @@index([isPrimary])
  @@map("email_providers")
  @@schema("core")
}

model SmsProvider {
  id              String   @id @default(uuid())
  providerName    String   @map("provider_name") // msg91 | twilio | ...
  // Implementation type, NOT a unique identifier — multiple rows with the
  // same code allowed (e.g. primary MSG91 + fallback MSG91 with different
  // sender IDs). Mirrors the email-provider fix from P0-15.
  providerCode    String   @map("provider_code")
  configuration   Json     // @encrypted
  senderId        String?  @map("sender_id")     // DLT-registered for India
  isPrimary       Boolean  @default(false) @map("is_primary")
  isActive        Boolean  @default(true) @map("is_active")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String?  @map("created_by_id")
  updatedById     String?  @map("updated_by_id")

  @@index([isActive])
  @@index([isPrimary])
  @@map("sms_providers")
  @@schema("core")
}

model WhatsappProvider {
  id              String   @id @default(uuid())
  providerName    String   @map("provider_name")
  providerCode    String   @map("provider_code")
  configuration   Json     // @encrypted
  phoneNumberId   String?  @map("phone_number_id")
  businessAccountId String? @map("business_account_id")
  webhookSecret   String?  @map("webhook_secret")
  isPrimary       Boolean  @default(false) @map("is_primary")
  isActive        Boolean  @default(true) @map("is_active")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String?  @map("created_by_id")
  updatedById     String?  @map("updated_by_id")

  notificationLogs NotificationLog[]

  @@index([isActive])
  @@index([isPrimary])
  @@map("whatsapp_providers")
  @@schema("core")
}

model CommunicationTemplate {
  id                String   @id @default(uuid())
  templateCode      String   @unique @map("template_code")
  name              String
  channel           String   // email | sms | whatsapp
  subjectTemplate   String?  @map("subject_template")
  bodyTemplate      String   @db.Text @map("body_template")
  variablesSchema   Json?    @map("variables_schema")
  // DLT (TRAI / India) compliance for SMS templates. Each registered
  // template gets a Telecom-issued ID; the SMS service refuses sends when
  // DLT enforcement is on and dltTemplateId is missing. Optional for
  // non-SMS templates.
  dltTemplateId     String?  @map("dlt_template_id")
  // WhatsApp-specific: Meta-approved templates have structured
  // header/footer/buttons and a namespace from the BSP.
  waApprovalStatus  String?  @map("wa_approval_status") // draft | submitted | approved | rejected
  waNamespace       String?  @map("wa_namespace")
  headerTemplate    String?  @map("header_template")
  footerTemplate    String?  @map("footer_template")
  buttonsTemplate   Json?    @map("buttons_template")
  isActive          Boolean  @default(true) @map("is_active")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdById       String?  @map("created_by_id")
  updatedById       String?  @map("updated_by_id")

  @@index([channel])
  @@index([isActive])
  @@map("communication_templates")
  @@schema("core")
}

model Notification {
  id                  String    @id @default(uuid())
  // Nullable so system-generated messages without a target user (anonymous
  // forgot-password sends, broadcast SMS, etc.) can still be recorded.
  recipientUserId     String?   @map("recipient_user_id")
  notificationType    String    @map("notification_type")
  title               String
  body                String    @db.Text
  isRead              Boolean   @default(false) @map("is_read")
  readAt              DateTime? @map("read_at")
  relatedEntityType   String?   @map("related_entity_type")
  relatedEntityId     String?   @map("related_entity_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  recipient           User?     @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  logs                NotificationLog[]

  @@index([recipientUserId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
  @@schema("core")
}

model NotificationLog {
  id                  String    @id @default(uuid())
  // Nullable: see comment on Notification.recipientUserId. A log row with no
  // anchoring Notification is allowed for system-emitted messages (rate-limit
  // tracking on anonymous sends, etc.).
  notificationId      String?   @map("notification_id")
  channel             String    // email | sms | whatsapp | inapp
  emailProviderId     String?   @map("email_provider_id")
  whatsappProviderId  String?   @map("whatsapp_provider_id")
  recipientAddress    String    @map("recipient_address")
  status              String    // queued | sent | delivered | failed | read
  sentAt              DateTime? @map("sent_at")
  deliveredAt         DateTime? @map("delivered_at")
  readAt              DateTime? @map("read_at")
  errorMessage        String?   @map("error_message")
  providerMessageId   String?   @map("provider_message_id")

  createdAt           DateTime  @default(now()) @map("created_at")

  notification        Notification?      @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  emailProvider       EmailProvider?     @relation(fields: [emailProviderId], references: [id], onDelete: SetNull)
  whatsappProvider    WhatsappProvider?  @relation(fields: [whatsappProviderId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([channel])
  @@index([status])
  @@index([providerMessageId])
  @@map("notification_log")
  @@schema("core")
}

