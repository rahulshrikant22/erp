{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "Modular Furniture ERP — Express + TypeScript + Prisma backend.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "dotenv -e ../.env -- vitest run",
    "test:watch": "dotenv -e ../.env -- vitest",
    "prisma": "dotenv -e ../.env -- prisma",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:migrate:dev": "dotenv -e ../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:check": "dotenv -e ../.env -- tsx scripts/db-check.ts",
    "db:seed": "dotenv -e ../.env -- tsx prisma/seed.ts",
    "db:reset": "dotenv -e ../.env -- prisma migrate reset --force"
  },
  "prisma": {
    "seed": "dotenv -e ../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1045.0",
    "@prisma/client": "^6.19.3",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.5",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mailgun.js": "^13.0.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "otpauth": "^9.5.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^6.19.3",
    "razorpay": "^2.9.6",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
