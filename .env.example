# =============================================================================
# Modular Furniture ERP — environment variables
# Copy this file to `.env` and fill in real values for local development.
# DO NOT commit .env (it is in .gitignore).
# =============================================================================

# --- Runtime ---
NODE_ENV=development

# --- Backend ---
PORT=4000
# PostgreSQL 16 connection string. Format:
# postgresql://<user>:<password>@<host>:<port>/<database>
# Example for a local Postgres install with default 'postgres' superuser:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_dev

# --- Auth secrets (use long random strings in real environments) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_me_with_a_DIFFERENT_64_byte_random_hex

# --- Frontend ---
# Note: ERP frontend uses port 3100 to leave 3000 free for other local dev servers.
FRONTEND_URL=http://localhost:3100

# --- Backend → Frontend bridge (used by Next.js to call the API) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Auth (P0-05) ---
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=60
AUTH_BCRYPT_COST=12

# Disable to skip HaveIBeenPwned API calls during password set / change
# (useful offline; only the first 5 chars of SHA-1 are sent — k-anonymity).
PASSWORD_BREACH_CHECK_ENABLED=true

# --- SMTP (placeholder for P0-05; real provider abstraction in P0-15) ---
# Leave SMTP_HOST empty to use a log-only transport (no real emails sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@erp.local
SMTP_FROM_NAME=Modular Furniture ERP

# --- SMS / DLT (P0-16) ---
# Set to "true" in production. When on, SMS sends require a registered
# dltTemplateId on the template (TRAI compliance for India).
DLT_ENFORCEMENT_ENABLED=true
# Per-recipient SMS send cap per hour.
SMS_RATE_LIMIT_PER_HOUR=5
