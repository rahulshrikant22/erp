{
  "name": "modular-furniture-erp",
  "version": "0.1.0",
  "private": true,
  "description": "ERP for modular furniture business — built phase-by-phase per /specs/PROMPTS_P0.md.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces --if-present",
    "start:backend": "npm run start --workspace=backend",
    "start:frontend": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-start.ps1",
    "db:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-stop.ps1",
    "db:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-status.ps1",
    "db:check": "npm run db:check --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "db:migrate:dev": "npm run db:migrate:dev --workspace=backend",
    "db:reset": "npm run db:reset --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:studio": "npm run db:studio --workspace=backend"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
